    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && echo '--- PreCompact Snapshot ---' && echo 'Modified files:' && git diff --name-only 2>/dev/null && echo 'Staged files:' && git diff --cached --name-only 2>/dev/null && echo 'Unstaged changes:' && git diff --stat 2>/dev/null"
