# ─── Rhiza Backend — Variables d'environnement ───────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=rhiza
PG_PASSWORD=
PG_DB=rhiza

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# JWT
JWT_SECRET=dev-secret-change-me-in-production!!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Logs endpoint (GET /logs)
LOGS_TOKEN=dev-logs-token-change-me!!
LOGS_BUFFER_SIZE=1000
